<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest ExtensionBundleId="com.fingerscrossed.qrcode.generator"
  ExtensionBundleName="QR Code Generator"
  ExtensionBundleVersion="1.3.0"
  Version="11.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.fingerscrossed.qrcode.generator.panel" Version="1.3.0" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <Host Name="ILST" Version="[28.0,31.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.fingerscrossed.qrcode.generator.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>QR Code Generator</Menu>
          <Geometry>
            <Size>
              <Height>520</Height>
              <Width>360</Width>
            </Size>
            <MinSize>
              <Height>460</Height>
              <Width>320</Width>
            </MinSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./icons/icon-light.png</Icon>
            <Icon Type="RollOver">./icons/icon-light.png</Icon>
            <Icon Type="DarkNormal">./icons/icon-dark.png</Icon>
            <Icon Type="DarkRollOver">./icons/icon-dark.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
